<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>WhatsApp Bot Logs</title>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
</head>
<body>
    <h2>📜 Riwayat Log Bot WhatsApp</h2>
    <table id="logsTable" class="display" style="width:100%">
        <thead>
            <tr>
                <th>Event</th>
                <th>Number</th>
                <th>Message</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>

    <script>
        $(document).ready(function() {
            $('#logsTable').DataTable({
                ajax: {
                    url: 'http://localhost:3000/logs?limit=100', // API dari Node.js
                    dataSrc: 'data'
                },
                columns: [
                    { data: 'event' },
                    { data: 'number' },
                    { data: 'message' },
                    { data: 'created_at' }
                ],
                pageLength: 25,
                order: [[3, 'desc']],
                responsive: true
            });

            // Auto reload setiap 5 detik
            setInterval(function() {
                $('#logsTable').DataTable().ajax.reload(null, false);
            }, 5000);
        });
    </script>
</body>
</html>
